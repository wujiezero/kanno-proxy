config global 'global'
	option enabled '1'
	option kernel 'mihomo'
	option mode 'rule'
	option log_level 'info'
	option ipv6 '0'

config dns 'dns'
	option enabled '1'
	option mode 'fake-ip'
	option listen_port '1053'
	list domestic_dns '114.114.114.114'
	list domestic_dns '223.5.5.5'
	list foreign_dns '8.8.8.8'
	list foreign_dns '1.1.1.1'

config rules 'rules'
	option geosite_cn 'DIRECT'
	option geoip_cn 'DIRECT'
	option default_policy 'PROXY'

config proxygroup 'group_proxy'
	option name 'PROXY'
	option type 'url-test'
	option url 'http://www.gstatic.com/generate_204'
	option interval '300'
	option tolerance '50'

config proxygroup 'group_fallback'
	option name 'FALLBACK'
	option type 'fallback'
	option url 'http://www.gstatic.com/generate_204'
	option interval '300'
