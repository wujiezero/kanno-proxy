{
	"luci-app-kanno": {
		"description": "Grant UCI and command access to KannoProxy",
		"read": {
			"uci": [ "kanno" ],
			"ubus": {
				"file": [ "exec", "read", "stat", "list" ]
			},
			"cgi-io": [ "exec" ],
			"file": {
				"/usr/bin/kanno": [ "exec" ],
				"/usr/bin/mihomo": [ "exec" ],
				"/usr/bin/sing-box": [ "exec" ],
				"/usr/bin/curl": [ "exec" ],
				"/etc/kanno/*": [ "read" ],
				"/var/log/kanno.log": [ "read" ]
			}
		},
		"write": {
			"uci": [ "kanno" ],
			"cgi-io": [ "upload" ],
			"ubus": {
				"file": [ "exec", "write" ]
			},
			"file": {
				"/sbin/uci": [ "exec" ],
				"/usr/bin/kanno": [ "exec" ],
				"/bin/sh": [ "exec" ],
				"/etc/kanno/*": [ "read", "write" ]
			}
		}
	}
}
