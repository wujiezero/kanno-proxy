#!/bin/sh
# TomFly - main control command

. /usr/lib/tomfly/common.sh
. /usr/lib/tomfly/capabilities.sh
. /usr/lib/tomfly/uri_parser.sh
. /usr/lib/tomfly/gen_mihomo.sh
. /usr/lib/tomfly/gen_singbox.sh
. /usr/lib/tomfly/nftables.sh
. /usr/lib/tomfly/dns.sh
. /usr/lib/tomfly/traffic.sh
. /usr/lib/tomfly/updater.sh

_kernel() { uci -q get tomfly.global.kernel 2>/dev/null || echo "mihomo"; }

# Which data-plane carries traffic into the kernel:
#   tproxy → tomfly's nftables + policy routing redirect (mihomo with TUN off)
#   tun    → the kernel's own TUN auto-route/auto-redirect handles everything
# sing-box only ships a TUN inbound here, so it is ALWAYS "tun"; mihomo uses
# tproxy unless the user turns TUN on. Running both at once double-captures the
# same traffic and breaks the proxy, so exactly one path is ever active.
_dataplane() {
    [ "$(_kernel)" = "singbox" ] && { echo "tun"; return; }
    [ "$(uci -q get tomfly.global.tun 2>/dev/null)" = "1" ] && echo "tun" || echo "tproxy"
}

# Ensure the TUN char device exists before a TUN-mode kernel starts. kmod-tun
# may be installed but its module not loaded (no /dev/net/tun), in which case
# the kernel silently fails to create its interface and nothing is proxied.
_ensure_tun_dev() {
    [ -c /dev/net/tun ] && return 0
    modprobe tun 2>/dev/null || insmod tun 2>/dev/null
    if [ ! -c /dev/net/tun ]; then
        mkdir -p /dev/net
        mknod /dev/net/tun c 10 200 2>/dev/null
        chmod 600 /dev/net/tun 2>/dev/null
    fi
    [ -c /dev/net/tun ]
}

# Validate the on-disk config for the active kernel (0 = valid).
_validate_config() {
    case "$1" in
    singbox) "$SINGBOX_BIN" check -c "$SINGBOX_CFG" >/tmp/tomfly-cfgtest.log 2>&1 ;;
    *)       "$MIHOMO_BIN" -d "$GEODATA_DIR" -f "$MIHOMO_CFG" -t >/tmp/tomfly-cfgtest.log 2>&1 ;;
    esac
}

# Validate ONE node in isolation (0 = the kernel accepts it).
_validate_node() {
    local kernel="$1" sec="$2"
    case "$kernel" in
    singbox)
        { printf '{"log":{"level":"fatal"},"outbounds":['; emit_singbox_proxy "$sec"; printf ']}'; } > /tmp/tomfly-nodetest.json
        "$SINGBOX_BIN" check -c /tmp/tomfly-nodetest.json >/dev/null 2>&1 ;;
    *)
        { printf 'mixed-port: 17890\nproxies:\n'; emit_proxy "$sec"; } > /tmp/tomfly-nodetest.yaml
        "$MIHOMO_BIN" -d "$GEODATA_DIR" -f /tmp/tomfly-nodetest.yaml -t >/dev/null 2>&1 ;;
    esac
}

# Echo section ids of every enabled+compatible node that FAILS validation.
_find_invalid_nodes() {
    local kernel="$1" sec
    for sec in $(uci show tomfly 2>/dev/null | sed -n "s/^tomfly\.\(proxy_[0-9a-f]*\)\.type=.*/\1/p"); do
        [ "$(uci -q get "tomfly.${sec}.enabled" 2>/dev/null)" = "0" ] && continue
        tomfly_node_incompat "$kernel" "$sec" >/dev/null 2>&1 || continue
        _validate_node "$kernel" "$sec" || printf '%s ' "$sec"
    done
}

start_kernel() {
    local kernel=$(_kernel)
    local bin cfg
    [ "$kernel" = "singbox" ] || kernel="mihomo"

    if [ "$kernel" = "singbox" ]; then
        bin="$SINGBOX_BIN"; cfg="$SINGBOX_CFG"
        . /usr/lib/tomfly/gen_singbox.sh
    else
        bin="$MIHOMO_BIN"; cfg="$MIHOMO_CFG"
        . /usr/lib/tomfly/gen_mihomo.sh
    fi

    if [ ! -x "$bin" ]; then
        log_error "$kernel not found, run: tomfly update $kernel"
        return 1
    fi

    # gen already skips kernel-incompatible nodes via the capability matrix.
    unset TOMFLY_EXCLUDE
    write_config "$cfg"

    # Safety net: if the config still fails to validate (e.g. a malformed field
    # the matrix can't see), drop the offending node(s) and regenerate so the
    # remaining good nodes still come up instead of the whole kernel dying.
    if ! _validate_config "$kernel"; then
        local bad
        bad=$(_find_invalid_nodes "$kernel")
        if [ -n "$bad" ]; then
            log_warn "dropping node(s) that failed validation: $bad"
            TOMFLY_EXCLUDE="$bad"
            write_config "$cfg"
            unset TOMFLY_EXCLUDE
        fi
        if ! _validate_config "$kernel"; then
            log_error "$kernel config invalid, not starting:"
            grep -iE 'error|fatal' /tmp/tomfly-cfgtest.log | head -3 | while read -r l; do log_error "  $l"; done
            return 1
        fi
    fi

    # Detach stdout/stderr from the invoking shell (SSH session). sing-box also
    # writes to log.output in config.json; this catches anything still on fd 1/2.
    if [ "$kernel" = "singbox" ]; then
        "$bin" run -c "$cfg" -D "$GEODATA_DIR" >>"$TOMFLY_LOG" 2>&1 &
        echo $! > "$SINGBOX_PID"
    else
        "$bin" -d "$GEODATA_DIR" -f "$cfg" >>"$TOMFLY_LOG" 2>&1 &
        echo $! > "$MIHOMO_PID"
    fi
    local kpid=$!

    # OOM hardening: when memory runs tight, sacrifice the proxy kernel before
    # SSH. Mark the kernel as a preferred OOM victim (+500) and protect every
    # dropbear (SSH) process (-800) so management access survives.
    [ -n "$kpid" ] && echo 500 > "/proc/$kpid/oom_score_adj" 2>/dev/null
    local dpid
    for dpid in $(pidof dropbear 2>/dev/null); do
        echo -800 > "/proc/$dpid/oom_score_adj" 2>/dev/null
    done

    log_info "$kernel started (pid $kpid)"
}

stop_kernel() {
    for pid_file in "$MIHOMO_PID" "$SINGBOX_PID"; do
        [ -f "$pid_file" ] || continue
        local pid=$(cat "$pid_file")
        kill "$pid" 2>/dev/null && log_info "stopped pid $pid"
        rm -f "$pid_file"
    done
    # Send SIGTERM, then poll until the kernel actually exits (up to ~5s).
    # sing-box needs this grace window to tear down its own auto_route /
    # auto_redirect state (ip rules + private routing tables); killing it too
    # early leaves that state behind and can lock out the router's own
    # management access. Only escalate to SIGKILL if it is still alive.
    killall mihomo sing-box 2>/dev/null
    local i=0
    while [ "$i" -lt 5 ]; do
        pidof mihomo >/dev/null 2>&1 || pidof sing-box >/dev/null 2>&1 || break
        sleep 1
        i=$(( i + 1 ))
    done
    if pidof mihomo >/dev/null 2>&1 || pidof sing-box >/dev/null 2>&1; then
        killall -9 mihomo sing-box 2>/dev/null
    fi
}

reload_kernel() {
    local kernel=$(_kernel)
    case "$kernel" in
    mihomo)
        . /usr/lib/tomfly/gen_mihomo.sh
        write_config "$MIHOMO_CFG"
        local pid=$(cat "$MIHOMO_PID" 2>/dev/null)
        [ -n "$pid" ] && kill -HUP "$pid" 2>/dev/null && log_info "mihomo reloaded"
        ;;
    *)
        stop_kernel
        start_kernel
        ;;
    esac
}

# Probe the local management channel (SSH / dropbear) on 127.0.0.1.
# Returns 0 ONLY when the port is definitively reachable; any uncertainty
# (no nc available, probe error) returns non-zero, so callers never roll back
# on a guess. Mirrors the busybox-nc style used in _tcp_probe_ms.
_mgmt_probe() {
    command -v nc >/dev/null 2>&1 || return 1
    local port
    port=$(uci -q get dropbear.@dropbear[0].Port 2>/dev/null)
    [ -n "$port" ] || port=22
    nc -z -w2 127.0.0.1 "$port" 2>/dev/null \
        || nc -z -w 2 127.0.0.1 "$port" 2>/dev/null
}

tomfly_start() {
    local lockfile="/tmp/tomfly.lock"
    # Acquire an exclusive flock(1) lock — no PID-recycling races, automatically
    # released when the shell exits.  flock is part of util-linux / busybox.
    mkdir -p /var/lock 2>/dev/null
    exec 9>"$lockfile"
    if ! flock -n 9; then
        log_warn "another tomfly instance holds the lock — aborting start"
        return 0
    fi
    log_info "TomFly starting..."

    # Capture the management-channel baseline BEFORE touching the data plane,
    # so we can detect (and undo) a start that locks us out of SSH.
    local mgmt_before=0
    _mgmt_probe && mgmt_before=1

    local plane=$(_dataplane)
    [ "$plane" = "tun" ] && _ensure_tun_dev

    start_kernel || return 1
    sleep 2

    # A TUN data-plane is only real if the kernel actually created its
    # interface. When it cannot (no kmod-tun matching the running kernel, a
    # virtualised env with no /dev/net/tun passthrough, etc.) fall back to
    # TPROXY so traffic is still proxied instead of leaking out unproxied.
    if [ "$plane" = "tun" ]; then
        local tun_if; [ "$(_kernel)" = "singbox" ] && tun_if="TomFly" || tun_if="Meta"
        if ! ip link show "$tun_if" >/dev/null 2>&1; then
            log_warn "TUN interface '$tun_if' did not come up — falling back to TPROXY"
            TOMFLY_FORCE_TPROXY=1; export TOMFLY_FORCE_TPROXY
            stop_kernel
            if [ "$(_kernel)" = "singbox" ]; then
                # sing-box has no TPROXY inbound configured by default — we
                # must generate a new config with a tproxy listener instead.
                log_warn "reconfiguring sing-box for TPROXY fallback..."
                _singbox_tproxy_fallback=1
                export _singbox_tproxy_fallback
                start_kernel || return 1
                unset _singbox_tproxy_fallback
            else
                start_kernel || return 1
            fi
            unset TOMFLY_FORCE_TPROXY
            sleep 1
            plane=tproxy
        fi
    fi

    if [ "$plane" = "tproxy" ]; then
        setup_routing
        load_nftables
        load_custom_rules
    else
        log_info "TUN data-plane — kernel manages routing; skipping tproxy nftables"
    fi
    setup_dns

    # Safety net: if SSH was reachable before we started but is not anymore,
    # the data plane has locked out management access — roll back immediately
    # instead of leaving the router unreachable. Only fires on a clear
    # before-reachable / after-unreachable transition to avoid false positives
    # (custom SSH port, no nc, transient probe failure → no rollback).
    if [ "$mgmt_before" = "1" ] && ! _mgmt_probe; then
        log_error "management channel lost after start — auto-rolling back to protect access"
        tomfly_stop
        return 1
    fi

    log_info "TomFly started"
    # flock released automatically when fd 9 closes (shell exits)
}

tomfly_stop() {
    log_info "TomFly stopping..."
    teardown_dns
    unload_nftables
    teardown_routing
    stop_kernel
    # Clean up TUN data-plane leftovers in case the kernel was killed before it
    # could remove its own auto-route/auto-redirect state (nft table + iface).
    nft delete table inet mihomo 2>/dev/null
    nft delete table inet sing-box 2>/dev/null
    ip link del Meta 2>/dev/null
    ip link del TomFly 2>/dev/null
    # Best-effort cleanup of sing-box auto_route leftovers (its own ip rules +
    # private routing tables) in case the kernel was killed before it could
    # self-clean. NOTE: sing-box's default table numbers vary by version
    # (commonly 2022 for IPv4 and 2023 for IPv6) — confirm on the real device.
    # All operations are best-effort and silenced.
    local _t _p
    for _t in 2022 2023; do
        ip route flush table "$_t" 2>/dev/null
        ip -6 route flush table "$_t" 2>/dev/null
    done
    # Drop any dangling ip rules that look up those tables (delete by priority).
    for _p in $(ip rule show 2>/dev/null | awk -F: '/lookup (2022|2023)/{gsub(/[^0-9]/,"",$1); if ($1!="") print $1}'); do
        ip rule del priority "$_p" 2>/dev/null
    done
    for _p in $(ip -6 rule show 2>/dev/null | awk -F: '/lookup (2022|2023)/{gsub(/[^0-9]/,"",$1); if ($1!="") print $1}'); do
        ip -6 rule del priority "$_p" 2>/dev/null
    done
    log_info "TomFly stopped"
}

tomfly_restart() {
    tomfly_stop
    sleep 1
    tomfly_start
}

tomfly_status() {
    local kernel=$(_kernel)
    local pid_file
    [ "$kernel" = "singbox" ] && pid_file="$SINGBOX_PID" || pid_file="$MIHOMO_PID"

    if [ -f "$pid_file" ] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
        echo "running"
    else
        echo "stopped"
    fi
}

# Add a proxy node from URI
tomfly_add() {
    local uri="$1"
    [ -z "$uri" ] && { echo "Usage: tomfly add <uri>"; exit 1; }
    local id
    id=$(uri_to_uci "$uri") && echo "Added node: $id" || echo "Failed to parse URI"
}

# Remove a node by id
tomfly_del() {
    local id="$1"
    [ -z "$id" ] && { echo "Usage: tomfly del <node_id>"; exit 1; }
    uci -q delete "tomfly.proxy_${id}" && uci commit tomfly && \
        echo "Deleted node: $id" || echo "Node not found: $id"
}

# List all nodes
tomfly_list() {
    uci show tomfly 2>/dev/null | grep "^tomfly\.proxy_.*\.name=" | \
        sed 's/tomfly\.proxy_\(.*\)\.name=\(.*\)/\1  \2/'
}

# Resolve a host to a single IP. Pure IP literals are returned as-is; domains
# are resolved best-effort via the system resolver. Prefers IPv4.
_resolve_host() {
    local host="$1" ip
    case "$host" in
    *:*) echo "$host"; return 0 ;;                       # IPv6 literal
    esac
    if echo "$host" | grep -qE '^([0-9]{1,3}\.){3}[0-9]{1,3}$'; then
        echo "$host"; return 0                            # IPv4 literal
    fi
    ip=$(nslookup "$host" 2>/dev/null \
        | awk '/^Address[ 0-9]*:/ && $NF !~ /:/ {print $NF}' \
        | grep -vE '^127\.|^0\.0\.0\.0$' | head -n1)
    echo "$ip"
}

_wan4_dev() {
    ip -4 route show default 2>/dev/null \
        | awk '{for (i = 1; i <= NF; i++) if ($i == "dev") { print $(i + 1); exit }}'
}

# Measure direct TCP reachability to host:port (milliseconds). Node server IPs are
# excluded from TUN routing in the generated config; probe with plain TCP first.
_tcp_probe_ms() {
    local ip="$1" port="$2" dev t ms start end

    t=$(curl -4 -o /dev/null -s -w '%{time_connect}' \
        --connect-timeout 5 --max-time 6 \
        "http://${ip}:${port}/" 2>/dev/null)
    ms=$(echo "$t" | awk '{printf "%d", $1 * 1000}')
    [ -n "$ms" ] && [ "$ms" -gt 0 ] && { echo "${ms}ms"; return 0; }

    dev=$(_wan4_dev)
    if [ -n "$dev" ]; then
        t=$(curl -4 -o /dev/null -s -w '%{time_connect}' \
            --interface "$dev" --connect-timeout 5 --max-time 6 \
            "http://${ip}:${port}/" 2>/dev/null)
        ms=$(echo "$t" | awk '{printf "%d", $1 * 1000}')
        [ -n "$ms" ] && [ "$ms" -gt 0 ] && { echo "${ms}ms"; return 0; }
    fi

    if command -v nc >/dev/null 2>&1; then
        start=$(date +%s)
        if nc -z -w5 "$ip" "$port" 2>/dev/null \
            || nc -z -w 5 "$ip" "$port" 2>/dev/null; then
            end=$(date +%s)
            ms=$(( (end - start) * 1000 ))
            [ "$ms" -lt 1 ] && ms=1
            echo "${ms}ms"
            return 0
        fi
    fi

    if command -v timeout >/dev/null 2>&1 && command -v nc >/dev/null 2>&1; then
        start=$(date +%s)
        if timeout 5 nc "$ip" "$port" </dev/null >/dev/null 2>&1; then
            end=$(date +%s)
            ms=$(( (end - start) * 1000 ))
            [ "$ms" -lt 1 ] && ms=1
            echo "${ms}ms"
            return 0
        fi
    fi

    echo "timeout"
}

_service_running() {
    local pid
    case "$(_kernel)" in
    singbox) pid=$(cat "$SINGBOX_PID" 2>/dev/null) ;;
    *)       pid=$(cat "$MIHOMO_PID" 2>/dev/null) ;;
    esac
    [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

# Probe a single outbound by tag via Clash API (dials that node only).
_clash_outbound_delay_ms() {
    local name="$1" enc resp ms
    [ -z "$name" ] && return 1
    enc=$(printf '%s' "$name" | sed 's/ /%20/g')
    resp=$(curl -sf --max-time 10 \
        "http://127.0.0.1:9090/proxies/${enc}/delay?url=http://www.gstatic.com/generate_204&timeout=5000" \
        2>/dev/null) || return 1
    ms=$(echo "$resp" | sed -n 's/.*"delay"[^0-9]*\([0-9]*\).*/\1/p' | head -n1)
    [ -n "$ms" ] && echo "$ms"
}

# Node test: direct TCP to the node server first; if blocked (common under GFW on
# bare proxy ports), fall back to the kernel probing that outbound by name.
tomfly_test() {
    local id="$1"
    local sec="proxy_${id}"
    local server name result ms
    server=$(uci -q get "tomfly.${sec}.server")
    local port=$(uci -q get "tomfly.${sec}.port")
    name=$(uci -q get "tomfly.${sec}.name")
    [ -z "$server" ] && { echo "Node not found"; exit 1; }
    [ -z "$port" ] && { echo "timeout"; return 0; }

    local ip; ip=$(_resolve_host "$server")
    [ -z "$ip" ] && { echo "timeout"; return 0; }

    result=$(_tcp_probe_ms "$ip" "$port")
    case "$result" in
    *ms) echo "$result"; return 0 ;;
    esac

    if _service_running && [ -n "$name" ]; then
        ms=$(_clash_outbound_delay_ms "$name")
        [ -n "$ms" ] && { echo "${ms}ms"; return 0; }
    fi

    echo "timeout"
}

tomfly_clear_log() {
    : > "$TOMFLY_LOG"
    echo "Log cleared"
}

# Backup TomFly configuration to a tar.gz
tomfly_backup() {
    local out="${1:-/tmp/tomfly-backup-$(date +%Y%m%d-%H%M%S).tar.gz}"
    local tmp="/tmp/tomfly-bkp-$$"
    mkdir -p "$tmp/tomfly"
    uci export tomfly > "$tmp/tomfly/config.uci" 2>/dev/null || true
    [ -d "$RULES_DIR" ] && cp -r "$RULES_DIR" "$tmp/tomfly/rules" 2>/dev/null
    [ -d "$GEODATA_DIR" ] && cp -r "$GEODATA_DIR" "$tmp/tomfly/geodata" 2>/dev/null
    (cd "$tmp" && tar -czf "$out" tomfly 2>/dev/null)
    rm -rf "$tmp"
    if [ -f "$out" ]; then
        echo "$out"
        log_info "backup saved to $out"
    else
        echo "backup failed" >&2
        return 1
    fi
}

# Restore TomFly configuration from a backup tar.gz
# Move a node up or down in the manual sort order
tomfly_reorder() {
    local id="$1" dir="$2"
    [ -z "$id" ] && { echo "Usage: tomfly reorder <node_id> up|down" >&2; return 1; }
    case "$dir" in up|down) ;; *) echo "Usage: tomfly reorder <node_id> up|down" >&2; return 1 ;; esac

    local sec="proxy_${id}" my_order
    my_order=$(uci -q get "tomfly.${sec}.order" 2>/dev/null)
    [ -z "$my_order" ] && { echo "node $id not found" >&2; return 1; }

    # Find adjacent node by iterating all proxy sections
    local other_sec="" other_order="" best_order o s
    if [ "$dir" = "up" ]; then best_order=0; else best_order=999999; fi

    for s in $(uci show tomfly 2>/dev/null | sed -n 's/^tomfly\.\(proxy_[0-9a-f]*\)\.type=.*/\1/p'); do
        [ "$s" = "$sec" ] && continue
        o=$(uci -q get "tomfly.${s}.order" 2>/dev/null)
        [ -z "$o" ] && continue
        if [ "$dir" = "up" ]; then
            [ "$o" -lt "$my_order" ] && [ "$o" -gt "$best_order" ] && { best_order="$o"; other_sec="$s"; }
        else
            [ "$o" -gt "$my_order" ] && [ "$o" -lt "$best_order" ] && { best_order="$o"; other_sec="$s"; }
        fi
    done

    if [ -z "$other_sec" ]; then
        [ "$dir" = "up" ] && echo "already at top" || echo "already at bottom"
        return 0
    fi

    other_order=$(uci -q get "tomfly.${other_sec}.order" 2>/dev/null)
    [ -z "$other_order" ] && { echo "adjacent node order not found" >&2; return 1; }

    # Swap orders
    uci -q set "tomfly.${sec}.order=${other_order}"
    uci -q set "tomfly.${other_sec}.order=${my_order}"
    uci commit tomfly
    echo "moved $id $dir"
}

tomfly_restore() {
    local src="$1"
    [ -z "$src" ] && { echo "Usage: tomfly restore <backup.tar.gz>"; return 1; }
    [ ! -f "$src" ] && { echo "backup file not found: $src" >&2; return 1; }
    local tmp="/tmp/tomfly-rst-$$"
    mkdir -p "$tmp"
    if ! tar -xzf "$src" -C "$tmp" 2>/dev/null; then
        log_error "invalid backup file: $src"
        rm -rf "$tmp"
        return 1
    fi
    # Restore UCI config
    if [ -f "$tmp/tomfly/config.uci" ]; then
        uci import tomfly < "$tmp/tomfly/config.uci" 2>/dev/null &&             uci commit tomfly && log_info "config restored"
    fi
    # Restore rule files
    if [ -d "$tmp/tomfly/rules" ]; then
        mkdir -p "$RULES_DIR"
        cp -r "$tmp/tomfly/rules/"* "$RULES_DIR/" 2>/dev/null &&             log_info "rules restored"
    fi
    # Restore geodata (skip if already newer)
    if [ -d "$tmp/tomfly/geodata" ] && [ ! -f "$GEODATA_DIR/version" ]; then
        mkdir -p "$GEODATA_DIR"
        cp -r "$tmp/tomfly/geodata/"* "$GEODATA_DIR/" 2>/dev/null &&             log_info "geodata restored"
    fi
    rm -rf "$tmp"
    echo "restored from $src"
}

case "${1:-help}" in
    start)   tomfly_start ;;
    stop)    tomfly_stop ;;
    restart) tomfly_restart ;;
    reload)  reload_kernel ;;
    status)  tomfly_status ;;
    add)     tomfly_add "$2" ;;
    del)     tomfly_del "$2" ;;
    list)    tomfly_list ;;
    test)      tomfly_test "$2" ;;
    clear_log) tomfly_clear_log ;;
    backup)       tomfly_backup "$2" ;;
    restore)      tomfly_restore "$2" ;;
    reorder)       tomfly_reorder "$2" "$3" ;;
    traffic)          tomfly_traffic ;;
    update)
        case "$2" in
        mihomo)  update_mihomo ;;
        singbox) update_singbox ;;
        geodata)         update_geodata ;;
        geodata_mihomo)  update_geodata_mihomo ;;
        geodata_singbox) update_geodata_singbox ;;
        core)    update_core ;;
        all)     update_core; update_mihomo; update_singbox; update_geodata ;;
        *)       echo "Usage: tomfly update {core|mihomo|singbox|geodata|geodata_mihomo|geodata_singbox|all}" ;;
        esac
        ;;
    *)
        cat <<-USAGE
TomFly v0.1.0
Commands:
  start              Start the proxy service
  stop               Stop the proxy service
  restart            Restart the proxy service
  reload             Reload config without restarting
  status             Show running status
  add <uri>          Add a proxy node from URI
  del <id>           Remove a proxy node
  list               List all proxy nodes
  test <id>          Test node connectivity
  backup [file]       Backup config + rules + geodata to tar.gz
  restore <file>      Restore from a backup tar.gz
  clear_log           Clear the log file
  update core         Update TomFly scripts (gen_*, tomfly)
  update mihomo      Update mihomo kernel
  update singbox     Update sing-box kernel
  update geodata          Update mihomo .dat + sing-box .srs rule-sets
  update geodata_mihomo   Update mihomo geoip.dat + geosite.dat only
  update geodata_singbox  Update sing-box geoip-cn.srs + geosite-cn.srs only
  update all         Update everything
USAGE
        ;;
esac
